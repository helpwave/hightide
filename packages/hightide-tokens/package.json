{
  "name": "@helpwave/hightide-tokens",
  "description": "Platform-agnostic design tokens for helpwave's hightide design language (shared by web + React Native)",
  "author": "helpwave <support@helpwave.de> (https://helpwave.de)",
  "homepage": "https://helpwave.de",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/helpwave/hightide.git",
    "directory": "packages/hightide-tokens"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MPL-2.0",
  "version": "0.12.7",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "8.5.0",
    "typescript": "5.9.3"
  }
}

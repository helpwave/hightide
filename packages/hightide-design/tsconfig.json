{
  "compilerOptions": {
    "target": "ES2019",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "declaration": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules"
  ]
}

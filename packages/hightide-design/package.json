{
  "name": "@helpwave/hightide-design",
  "description": "helpwave design tokens for hightide",
  "author": "helpwave <support@helpwave.de> (https://helpwave.de)",
  "homepage": "https://helpwave.de",
  "repository": {
    "url": "git+https://github.com/helpwave/hightide.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "AGPL-3.0-only",
  "version": "0.0.3",
  "type": "module",
  "files": [
    "src"
  ],
  "exports": {
    "./helpers": {
      "types": "./src/helpers/index.ts",
      "default": "./src/helpers/index.ts"
    },
    "./hooks": {
      "types": "./src/hooks/index.ts",
      "default": "./src/hooks/index.ts"
    },
    "./tokens": {
      "types": "./src/tokens/index.ts",
      "default": "./src/tokens/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    }
  },
  "scripts": {
    "clean": "pnpm run barrel && rm -rf node_modules",
    "init": "pnpm run barrel",
    "barrel": "node node_modules/@helpwave/hightide-utils/scripts/barrel.js",
    "barrel:check": "pnpm run barrel --check",
    "build": "pnpm run barrel",
    "lint": "eslint .",
    "test": "pnpm run barrel:check"
  },
  "dependencies": {
    "@helpwave/hightide-utils": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@helpwave/eslint-config": "0.0.11",
    "@types/node": "20.19.43",
    "@types/react": "19.2.3",
    "eslint": "9.31.0",
    "react": "19.2.3",
    "typescript": "5.7.2"
  },
  "keywords": [
    "design-tokens",
    "typescript"
  ],
  "bugs": {
    "url": "https://github.com/helpwave/hightide/issues"
  }
}

{
  "compilerOptions": {
    "target": "ES2019",
    "lib": [
      "ES2020",
      "ES2020.Intl",
      "DOM"
    ],
    "moduleResolution": "bundler",
    "module": "ESNext",
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "declarationDir": "dist",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src",
    "stories"
  ],
  "exclude": [
    "src/storybook",
    "dist",
    "node_modules"
  ]
}
{
  "compilerOptions": {
    "target": "ES2019",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "outDir": "dist",
    "rootDir": ".",
    "declaration": false,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "src",
    "tests"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}

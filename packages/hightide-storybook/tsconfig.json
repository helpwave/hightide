{
  "compilerOptions": {
    "target": "ES2019",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    ".storybook",
    "src"
  ],
  "exclude": [
    "node_modules",
    "storybook-static"
  ]
}

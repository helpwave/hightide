{
  "compilerOptions": {
    "target": "ES2019",
    "lib": ["ES2019", "DOM", "ES2020.Intl", "ES2021.Intl"],
    "moduleResolution": "bundler",
    "module": "ESNext",
    "jsx": "react-native",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "src",
    "stories"
  ],
  "exclude": [
    "src/storybook",
    "node_modules"
  ]
}
